# Anthropic API key — required to power the chat backend.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional Supabase configuration. The default build uses a local
# file-backed BM25 index and does not need a database. Set these only
# if you want to swap the retrieval layer for pgvector / Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
