# Anthropic API key — required to power the chat backend.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional Supabase configuration. When set, chat history persists to
# Postgres and the left sidebar shows past conversations. When unset,
# chats live in localStorage on the user's device.
#
# Supabase introduced new API keys in mid-2025; new projects no longer
# get the legacy `anon` / `service_role` keys. Use the dashboard's
# "API Keys" page:
#   - Project URL                 → NEXT_PUBLIC_SUPABASE_URL
#   - Secret keys → "Default"     → SUPABASE_SECRET_KEY  (sb_secret_…)
#
# If you have a pre-Nov 2025 project that still uses service_role, you
# can set SUPABASE_SERVICE_ROLE_KEY instead — the server reads either.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SECRET_KEY=
