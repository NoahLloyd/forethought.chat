# Default Anthropic backend.
#
# The chat route prefers the local `claude` CLI (subscription-billed): if
# `claude` is on PATH and you've signed in once, every turn spawns
# `claude -p` and bills your Pro/Max subscription — leave the API key
# blank in that case.
#
# When the CLI isn't on PATH (typical for a deployed Vercel-style host),
# the route falls through to the Anthropic API and reads this key. Get
# one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Optional override:
#   LIBRARIAN_TRANSPORT=cli   # always use claude CLI; 4xx if missing
#   LIBRARIAN_TRANSPORT=api   # always use the API SDK
# Leave unset to auto-detect (CLI when present, API otherwise).
# LIBRARIAN_TRANSPORT=

# Optional Supabase configuration. When set, chat history persists to
# Postgres and the left sidebar shows past conversations. When unset,
# chats live in localStorage on the user's device.
#
# Supabase introduced new API keys in mid-2025; new projects no longer
# get the legacy `anon` / `service_role` keys. Use the dashboard's
# "API Keys" page:
#   - Project URL                 → NEXT_PUBLIC_SUPABASE_URL
#   - Secret keys → "Default"     → SUPABASE_SECRET_KEY  (sb_secret_…)
#
# If you have a pre-Nov 2025 project that still uses service_role, you
# can set SUPABASE_SERVICE_ROLE_KEY instead — the server reads either.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SECRET_KEY=
